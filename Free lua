    if IsStealing then return end
    local animal = getNearestAnimal()
    if animal then
        local prompt = findPrompt(animal)
        if prompt then buildStealCallbacks(prompt) executeInternalStealAsync(prompt, animal, spot1_sequence, 1) end
    end
end)

