-- ===================== EXECUTE STEAL =====================
local function executeInternalStealAsync(prompt, animalData, sequence, zDir)
    local data = InternalStealCache[prompt]
    if not data or not data.ready or IsStealing then return end
    zDir = zDir or 1
    data.ready = false
    IsStealing = true
    StealProgress = 0
    CurrentStealTarget = animalData
    local tpDone = false
    task.spawn(function()
        for _, fn in ipairs(data.holdCallbacks) do task.spawn(fn) end
        local startTime = tick()
        while tick() - startTime < 1.3 do
            StealProgress = (tick() - startTime) / 1.3
            if StealProgress >= 0.73 and not tpDone then
                tpDone = true
                local hrp = getHRP()
                if hrp then
                    local char = player.Character
                    local hum = char and char:FindFirstChildOfClass("Humanoid")
                    local bp = player:FindFirstChild("Backpack")
                    if hum and bp then
                        local carpet = bp:FindFirstChild("Flying Carpet")
                        if carpet then hum:EquipTool(carpet) task.wait(0.1) end
                    end
                    hrp.CFrame = sequence[1] task.wait(0.1)
                    hrp.CFrame = sequence[2] task.wait(0.2)
                    local d1 = (hrp.Position - pos1).Magnitude
                    local d2 = (hrp.Position - pos2).Magnitude
                    local finalPos = d1 < d2 and pos1 or pos2
                    local lookTarget = d1 < d2 and standing2 or standing1
                    hrp.CFrame = CFrame.new(finalPos, Vector3.new(lookTarget.X, finalPos.Y, lookTarget.Z))
                    task.spawn(resetCameraForward)

                    -- Auto play seulement si la checkbox est cochée
                    local shouldAutoPlay = (zDir == 1 and autoLeftEnabled) or (zDir == -1 and autoRightEnabled)
                    if shouldAutoPlay then
                        task.spawn(function()
                            task.wait(0.4)
                            local c = player.Character
                            local h = c and c:FindFirstChildOfClass("Humanoid")
                            local root = c and c:FindFirstChild("HumanoidRootPart")
                            if h and root then
                                local startPos = root.Position
                                local targetPos = Vector3.new(startPos.X, startPos.Y, startPos.Z + (60 * zDir))
                                local moveDir = Vector3.new(0, 0, zDir)
                                local moveSpeed = targetSpeed
                                local duration = (60 / moveSpeed) + 0.5
                                local elapsed = 0
                                root.CFrame = CFrame.new(root.Position, root.Position + moveDir)
                                local conn
                                conn = RunService.Stepped:Connect(function(_, dt)
                                    elapsed = elapsed + dt
                                    local cr = player.Character
                                    local hr = cr and cr:FindFirstChild("HumanoidRootPart")
                                    if not hr then conn:Disconnect() return end
                                    local distLeft = (Vector3.new(targetPos.X, hr.Position.Y, targetPos.Z) - Vector3.new(hr.Position.X, hr.Position.Y, hr.Position.Z)).Magnitude
                                    if distLeft < 2 or elapsed > duration then
                                        hr.Velocity = Vector3.new(0, hr.Velocity.Y, 0)
                                        conn:Disconnect()
                                        return
                                    end
                                    hr.Velocity = Vector3.new(
                                        moveDir.X * moveSpeed,
                                        hr.Velocity.Y,
                                        moveDir.Z * moveSpeed
                                    )
                                end)
                            end
                        end)
                    end
                end
            end
            task.wait()
        end
        for _, fn in ipairs(data.triggerCallbacks) do task.spawn(fn) end
        task.wait(0.2)
        while StealProgress > 0 do
            StealProgress = math.max(0, StealProgress - 0.07)
            task.wait(0.02)
        end
        StealProgress = 0
        data.ready = true
        IsStealing = false
        CurrentStealTarget = nil
    end)
end

local function getNearestAnimal()
    local hrp = getHRP()
    if not hrp then return nil end
    local nearest, dist = nil, math.huge
    for _, animal in ipairs(allAnimalsCache) do
        local d = (hrp.Position - animal.worldPosition).Magnitude
        if d < dist and d <= AUTO_STEAL_PROX_RADIUS then dist = d nearest = animal end
    end
    return nearest
end

