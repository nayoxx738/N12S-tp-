-- ===================== CAMERA =====================
local camera = workspace.CurrentCamera
local BRAINROT_CENTER = Vector3.new(-352.98, -6.75, 60)

local function applyCam(hrp)
    local pos = hrp.Position
    local flatTarget = Vector3.new(BRAINROT_CENTER.X, pos.Y, BRAINROT_CENTER.Z)
    hrp.CFrame = CFrame.new(pos, flatTarget)
    local lookVec = (flatTarget - pos).Unit
    local camPos = pos - lookVec * 14 + Vector3.new(0, 8, 0)
    camera.CFrame = CFrame.new(camPos, pos + lookVec * 5 + Vector3.new(0, 2, 0))
end

local function resetCameraForward()
    local char = player.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local pos = hrp.Position
    local distS1 = (pos - standing1).Magnitude
    local distS2 = (pos - standing2).Magnitude
    if distS1 >= 15 and distS2 >= 15 then return end
    local timings = {0.2, 0.3, 0.4, 0.5}
    for _, t in ipairs(timings) do
        task.delay(t, function()
            local c = player.Character
            local h = c and c:FindFirstChild("HumanoidRootPart")
            if h then applyCam(h) end
        end)
    end
end

